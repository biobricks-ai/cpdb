  "@id": "https://brickyard.biobricks.ai/brick/cpdb",
  "dcterms:title": "Carcinogenic Potency Database (CPDB)",
  "dcterms:description": "Results of 6,540 chronic, long-term animal cancer tests on 1,547 chemicals from NCI/NTP bioassays and scientific literature. Contains TD50 potency values, target organs, species/strain data, and carcinogenicity opinions. SMILES added via PubChem CAS mapping.",
  "dcterms:license": "https://www.nlm.nih.gov/databases/download/terms_and_conditions.html",
